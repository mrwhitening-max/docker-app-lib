# ============================================
# PROMETHEUS CONFIGURATION
# ============================================

# Prometheus Port
PROMETHEUS_PORT=9090

# Prometheus Service Name in Consul
PROMETHEUS_SERVICE_NAME=prometheus

# Daten Retention (wie lange Metriken gespeichert werden)
# Beispiel: 15d, 30d, 90d
PROMETHEUS_RETENTION=15d

# Prometheus Scrape Tag für Consul Service Discovery
# Nur Services mit diesem Tag werden automatisch gescraped
PROMETHEUS_SCRAPE_TAG=metrics

# ============================================
# HOME ASSISTANT CONFIGURATION
# ============================================

# IP-Adresse der Home Assistant VM
# Beispiel: 192.168.2.30
HA_HOST=

# Long-Lived Access Token aus Home Assistant
# Erstellen unter: Profil → Sicherheit → Langlebige Zugangstoken
HA_BEARER_TOKEN=

# ============================================
# CONSUL CONFIGURATION
# ============================================

# Version des Consul Docker Images
CONSUL_VERSION=1.22.3

# IP-Adresse des Consul Servers
# Beispiel: 192.168.2.20
CONSUL_SERVER_IP=

# Eindeutiger Name dieses Consul Nodes
CONSUL_NODE_NAME=lxc-prometheus

# Datacenter Name (identisch auf allen Nodes)
CONSUL_DATACENTER=homelab

# Log-Level
# Optionen: TRACE, DEBUG, INFO, WARN, ERROR
CONSUL_LOG_LEVEL=INFO

# ============================================
# GOSSIP ENCRYPTION
# ============================================

# Symmetrischer Verschlüsselungsschlüssel für Gossip Traffic
# Vom Consul Server kopieren – MUSS auf allen Nodes identisch sein!
CONSUL_GOSSIP_KEY=

# ============================================
# RPC TLS
# ============================================

# CA Public Key als Base64
# Vom Consul Server kopieren:
#   docker exec consul-server base64 /consul-agent-ca.pem | tr -d '\n'
# Nur der Public Key – identisch auf allen Agent Nodes
# Kein eigenes Cert generieren! auto_encrypt holt den Rest automatisch.
CONSUL_CA_CERT_B64=