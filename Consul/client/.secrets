# ============================================
# CONSUL AGENT CONFIGURATION
# ============================================

# Version des Consul Docker Images
CONSUL_VERSION=1.22.3

# IP-Adresse des Consul Servers
# Beispiel: 192.168.2.20
CONSUL_SERVER_IP=

# Eindeutiger Name dieses Consul Nodes
# Beispiel: lxc-n8n, lxc-reactive-resume
CONSUL_NODE_NAME=

# Datacenter Name (identisch auf allen Nodes)
# Beispiel: homelab, dc1
CONSUL_DATACENTER=homelab

# Log-Level
# Optionen: TRACE, DEBUG, INFO, WARN, ERROR
CONSUL_LOG_LEVEL=INFO

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Netzwerk-Interface für IP-Erkennung
# Prüfen mit: ip addr show
NETWORK_INTERFACE=eth0

# ============================================
# GOSSIP ENCRYPTION
# ============================================

# Symmetrischer Verschlüsselungsschlüssel für Gossip Traffic
# Vom Consul Server kopieren – MUSS auf allen Nodes identisch sein!
CONSUL_GOSSIP_KEY=

# ============================================
# RPC TLS
# ============================================

# CA Public Key als Base64
# Vom Consul Server kopieren:
#   docker exec consul-server base64 /consul-agent-ca.pem | tr -d '\n'
# Nur der Public Key – identisch auf allen Agent Nodes
# Kein eigenes Cert generieren! auto_encrypt holt den Rest automatisch.
CONSUL_CA_CERT_B64=
