# ============================================
# CONSUL SERVER CONFIGURATION
# ============================================

# Datacenter Name (identisch auf allen Nodes)
# Beispiel: homelab, dc1, production
CONSUL_DATACENTER=homelab

# Log-Level für Consul Server
# Optionen: TRACE, DEBUG, INFO, WARN, ERROR
CONSUL_LOG_LEVEL=INFO

# IP-Adresse des Consul Servers (bind_addr)
# Die IP des Netzwerk-Interfaces auf dem Consul lauscht
# Beispiel: 192.168.2.20
CONSUL_BIND_IP=

# IP-Adresse die anderen Nodes angezeigt wird (advertise_addr)
# Normalerweise identisch mit CONSUL_BIND_IP
# Beispiel: 192.168.2.20
CONSUL_ADVERTISE_IP=

# ============================================
# GOSSIP ENCRYPTION
# ============================================

# Symmetrischer Verschlüsselungsschlüssel für Gossip Traffic
# Generieren mit: docker exec consul-server consul keygen
# MUSS auf allen Nodes identisch sein!
# Leer lassen beim ersten Start (Day-0)
CONSUL_GOSSIP_KEY=

# ============================================
# RPC TLS
# ============================================

# CA Public Key
# Generieren mit: base64 /root/consul-agent-ca.pem | tr -d '\n'
# Vorher aus Container holen: docker cp consul-server:/consul-agent-ca.pem /root/
# MUSS auf allen Agent Nodes identisch sein!
# Leer lassen beim ersten Start (Day-0)
CONSUL_CA_CERT_B64=

# CA Private Key
# Generieren mit: base64 /root/consul-agent-ca-key.pem | tr -d '\n'
# Vorher aus Container holen: docker cp consul-server:/consul-agent-ca-key.pem /root/
# NIEMALS auf Agents verteilen! Nur auf dem Server!
# Leer lassen beim ersten Start (Day-0)
CONSUL_CA_KEY_B64=

# Server Zertifikat
# Generieren mit: base64 /root/homelab-server-consul-0.pem | tr -d '\n'
# Vorher aus Container holen: docker cp consul-server:/homelab-server-consul-0.pem /root/
# Nur auf dem Server!
# Leer lassen beim ersten Start (Day-0)
CONSUL_SERVER_CERT_B64=

# Server Private Key
# Generieren mit: base64 /root/homelab-server-consul-0-key.pem | tr -d '\n'
# Vorher aus Container holen: docker cp consul-server:/homelab-server-consul-0-key.pem /root/
# Nur auf dem Server!
# Leer lassen beim ersten Start (Day-0)
CONSUL_SERVER_KEY_B64=

# ============================================
# DAY-0 WORKFLOW
# ============================================
# 1. Alle Werte leer lassen, docker compose up -d
# 2. Gossip Key generieren:
#      docker exec consul-server consul keygen
#      → CONSUL_GOSSIP_KEY eintragen
# 3. Certs generieren:
#      docker exec consul-server consul tls ca create
#      docker exec consul-server consul tls cert create -server -dc homelab
# 4. Certs aus Container holen:
#      docker cp consul-server:/consul-agent-ca.pem /root/
#      docker cp consul-server:/consul-agent-ca-key.pem /root/
#      docker cp consul-server:/homelab-server-consul-0.pem /root/
#      docker cp consul-server:/homelab-server-consul-0-key.pem /root/
# 5. Base64 generieren und eintragen:
#      base64 /root/consul-agent-ca.pem | tr -d '\n'          → CONSUL_CA_CERT_B64
#      base64 /root/consul-agent-ca-key.pem | tr -d '\n'      → CONSUL_CA_KEY_B64
#      base64 /root/homelab-server-consul-0.pem | tr -d '\n'  → CONSUL_SERVER_CERT_B64
#      base64 /root/homelab-server-consul-0-key.pem | tr -d '\n' → CONSUL_SERVER_KEY_B64
# 6. docker compose down && docker compose up -d
#    → Consul startet mit Gossip + TLS
# 7. CONSUL_CA_CERT_B64 auf alle Agent .env verteilen
#    → Agents neu starten → auto_encrypt holt Rest automatisch
