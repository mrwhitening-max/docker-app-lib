# ============================================
# CONSUL SERVER CONFIGURATION
# ============================================

# Datacenter Name (identisch auf allen Nodes)
# Beispiel: homelab, dc1, production
CONSUL_DATACENTER=homelab

# Log-Level für Consul Server
# Optionen: TRACE, DEBUG, INFO, WARN, ERROR
CONSUL_LOG_LEVEL=INFO

# IP-Adresse des Consul Servers (bind_addr)
# Die IP des Netzwerk-Interfaces auf dem Consul lauscht
# Beispiel: 192.168.2.20
CONSUL_BIND_IP=

# IP-Adresse die anderen Nodes angezeigt wird (advertise_addr)
# Normalerweise identisch mit CONSUL_BIND_IP
# Beispiel: 192.168.2.20
CONSUL_ADVERTISE_IP=

# ============================================
# GOSSIP ENCRYPTION
# ============================================

# Symmetrischer Verschlüsselungsschlüssel für Gossip Traffic
# Generieren mit: docker exec consul-server consul keygen
# MUSS auf allen Nodes identisch sein!
CONSUL_GOSSIP_KEY=

# ============================================
# RPC TLS
# ============================================

# CA Public Key
# Generieren mit: base64 /root/consul-agent-ca.pem | tr -d '\n'
# MUSS auf allen Nodes identisch sein!
CONSUL_CA_CERT_B64=

# CA Private Key
# Generieren mit: base64 /root/consul-agent-ca-key.pem | tr -d '\n'
# NIEMALS auf Agents verteilen! Nur auf dem Server!
CONSUL_CA_KEY_B64=

# Server Zertifikat
# Generieren mit: base64 /root/homelab-server-consul-0.pem | tr -d '\n'
# Nur auf dem Server!
CONSUL_SERVER_CERT_B64=

# Server Private Key
# Generieren mit: base64 /root/homelab-server-consul-0-key.pem | tr -d '\n'
# Nur auf dem Server!
CONSUL_SERVER_KEY_B64=
