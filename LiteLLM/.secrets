# ============================================
# LITELLM CONFIGURATION
# ============================================

# Master Key für API-Authentifizierung
# Wird als Bearer Token bei allen API-Anfragen verwendet
# Beispiel: sk-1234 oder ein sicherer zufälliger String
LITELLM_MASTER_KEY=

# ============================================
# UI CONFIGURATION
# ============================================

# Benutzername für das LiteLLM Admin-UI
UI_USERNAME=

# Passwort für das LiteLLM Admin-UI
UI_PASSWORD=

# ============================================
# POSTGRESQL CONFIGURATION
# ============================================

# PostgreSQL Benutzername
LITELLM_POSTGRES_USER=postgres

# PostgreSQL Passwort
LITELLM_POSTGRES_PASSWORD=

# PostgreSQL Hostname (Docker Service Name)
LITELLM_POSTGRES_HOST=litellm_db

# PostgreSQL Port
LITELLM_POSTGRES_PORT=5432

# PostgreSQL Datenbankname
LITELLM_POSTGRES_DB=postgres

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis Hostname (Docker Service Name)
LITELLM_REDIS_HOST=litellm_redis

# Redis Port
LITELLM_REDIS_PORT=6379

# ============================================
# OLLAMA CONFIGURATION
# ============================================

# Basis-URL der entfernten Ollama-Instanz
# Beispiel: http://192.168.2.50:11434
OLLAMA_API_BASE=

# ============================================
# ANTHROPIC CONFIGURATION
# ============================================

# Anthropic API Key
# Erstellen unter: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ============================================
# GEMINI CONFIGURATION
# ============================================

# Bis zu 3 Gemini API Keys für Load Balancing
# Erstellen unter: aistudio.google.com → API Keys
GEMINI_API_KEY=
GEMINI_API_KEY2=
GEMINI_API_KEY3=

# ============================================
# OPENROUTER CONFIGURATION
# ============================================

# Bis zu 3 OpenRouter API Keys für Load Balancing
# Erstellen unter: openrouter.ai → Keys
OPENROUTER_API_KEY=
OPENROUTER_API_KEY2=
OPENROUTER_API_KEY3=
